ENVIRONMENT=development
CORS_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql+asyncpg://visionvault:visionvault@localhost:5432/visionvault

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=image_embeddings

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=visionvault
MINIO_SECRET_KEY=visionvault123
MINIO_BUCKET_NAME=images
MINIO_USE_SSL=false

JWT_SECRET=change-me-access-secret
JWT_LIFELINE_SECONDS=900
REFRESH_TOKEN_SECRET=change-me-refresh-secret
REFRESH_TOKEN_LIFETIME_SECONDS=604800

UPLOAD_MAX_SIZE_MB=25
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp

CLIP_MODEL=Vit-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k